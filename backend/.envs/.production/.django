# General
# ------------------------------------------------------------------------------
# DJANGO_READ_DOT_ENV_FILE=True
DJANGO_SETTINGS_MODULE=config.settings.production
# Generar secret key con el comando 
# python3 -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=
DJANGO_ADMIN_URL=BPWPq0SDOy6rSlfMaA5xu8gc0gf9dw36/
DJANGO_ALLOWED_HOSTS=.plantilla.yoyodr.dev
DJANGO_CSRF_TRUSTED_ORIGINS=https://plantilla.yoyodr.dev
DJANGO_CORS_ALLOWED_ORIGINS=https://plantilla.yoyodr.dev
CORS_ALLOW_CREDENTIALS=False
DJANGO_NAME_LOG_FILE=django_prod
DJANGO_DEBUG=False

# Security
# ------------------------------------------------------------------------------
# TIP: better off using DNS, however, redirect is OK too
DJANGO_SECURE_SSL_REDIRECT=False

# Database
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://${PGB_POSTGRES_USER}:${PGB_POSTGRES_PASSWORD}@${PGB_POSTGRES_HOST}:${PGB_POSTGRES_PORT}/${PGB_POSTGRES_DB}

# Email
# ------------------------------------------------------------------------------
DJANGO_SERVER_EMAIL=


# Gunicorn
# ------------------------------------------------------------------------------
WEB_CONCURRENCY=4


# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery
# ------------------------------------------------------------------------------

# Flower
CELERY_FLOWER_USER=debug
CELERY_FLOWER_PASSWORD=debug

# JWT
# ------------------------------------------------------------------------------
JWT_REFRESH_TOKEN_DAYS=7
JWT_COOKIE_SECURE=true

# Traefik / Domain
# ------------------------------------------------------------------------------
# Dominio publico del deploy (Dokploy Traefik enruta por este Host).
# El Traefik interno (servicio `traefik` del compose) usa ${DOMAIN} en
# traefik.template.yml y enruta /api/ -> django, /api/media/ -> nginx,
# resto -> frontend.
DOMAIN=plantilla.yoyodr.dev

# VITE_API_URL se inyecta como build arg del frontend. En produccion el
# frontend consume el mismo dominio que el backend (Traefik enruta
# ${DOMAIN}/api/* a Django), por eso se usa ruta relativa.
VITE_API_URL=/

# Dokploy — limites de recursos por servicio
# ------------------------------------------------------------------------------
# docker-compose.dokploy.yml usa estos valores en `deploy.resources.limits`.
# Si no se definen, el compose aplica el default `:-1` / `:-1g`.
# Formato: cpus = numero o decimal ('0.5', '1', '2'), memory = '<num><unidad>'
# donde unidad = b|k|m|g (ej. '512m', '1g', '2g').
# Los `reservations` del compose ya tienen valores seguros por defecto
# (cpus '0.1'-'0.5', memory 123M-256M); estos `limits` son el techo maximo.
DJANGO_CPU=1
DJANGO_RAM=1g
PGBOUNCER_CPU=1
PGBOUNCER_RAM=1g
TRAEFIK_CPU=1
TRAEFIK_RAM=1g
CELERYWORKER_CPU=1
CELERYWORKER_RAM=1g
CELERYBEAT_CPU=1
CELERYBEAT_RAM=1g
NGINX_CPU=1
NGINX_RAM=1g
FRONTEND_CPU=1
FRONTEND_RAM=1g

# Numero de replicas del servicio `celeryworker` (compose: `replicas: ${CANT_WORKERS_CELERY:-2}`).
# Sube este valor si tienes picos de tareas async; cada replica consume CELERYWORKER_CPU/RAM.
CANT_WORKERS_CELERY=2
